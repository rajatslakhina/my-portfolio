# GitHub Blog Integration
# Set these to fetch blog posts from your GitHub repo
GITHUB_BLOG_OWNER=rajatslakhina
GITHUB_BLOG_REPO=AI-Knowledge

# Optional: GitHub Personal Access Token (avoids API rate limits)
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Site URL (used in sitemap and Open Graph)
NEXT_PUBLIC_SITE_URL=https://rajatlakhina.com
